    android:height="54dp"
    android:viewportWidth="48"
    android:viewportHeight="54">

    <!-- Outer triangle -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#E8720C"
        android:strokeWidth="2"
        android:pathData="M24,3 L45,50 L3,50 Z"/>

    <!-- Center vertical hairline -->
    <path
