    <!-- Iris -->
    <path
        android:fillColor="#E8720C"
        android:pathData="M24,37 m-3.2,0 a3.2,3.2 0 1,0 6.4,0 a3.2,3.2 0 1,0 -6.4,0"/>

    <!-- Highlight -->
    <path
        android:fillColor="#FF9533"
