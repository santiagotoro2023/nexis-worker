<?xml version="1.0" encoding="utf-8"?>
<!-- NeXiS logo: triangle with eye — orange on transparent (background layer provides dark bg) -->
<!-- Safe zone: 72x72 centered in 108x108, so drawable content from ~18,18 to ~90,90 -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Outer triangle — scaled to fit within adaptive icon safe zone (18-90) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#E8720C"
        android:strokeWidth="3"
        android:pathData="M54,24 L86,84 L22,84 Z"/>

    <!-- Center vertical hairline -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#E8720C"
        android:strokeWidth="0.9"
        android:strokeAlpha="0.35"
        android:pathData="M54,24 L54,84"/>

    <!-- Eye outer ring -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#E8720C"
        android:strokeWidth="2"
        android:pathData="M54,65 m-11,0 a11,11 0 1,0 22,0 a11,11 0 1,0 -22,0"/>

    <!-- Iris (filled orange) -->
    <path
        android:fillColor="#E8720C"
        android:pathData="M54,65 m-5,0 a5,5 0 1,0 10,0 a5,5 0 1,0 -10,0"/>

    <!-- Pupil highlight -->
    <path
        android:fillColor="#FF9533"
        android:pathData="M54,65 m-2,0 a2,2 0 1,0 4,0 a2,2 0 1,0 -4,0"/>

</vector>
