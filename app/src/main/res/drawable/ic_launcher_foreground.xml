<?xml version="1.0" encoding="utf-8"?>
<!-- NeXiS logo: triangle with eye — orange on transparent (background layer provides dark bg) -->
<!-- Safe zone: 72x72 centered in 108x108, so drawable content from ~18,18 to ~90,90 -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Outer triangle — well within adaptive icon safe zone with generous margins -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#E8720C"
        android:strokeWidth="2.5"
        android:pathData="M54,30 L80,78 L28,78 Z"/>

    <!-- Center vertical hairline -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#E8720C"
        android:strokeWidth="0.8"
        android:strokeAlpha="0.35"
        android:pathData="M54,30 L54,78"/>

    <!-- Eye outer ring -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#E8720C"
        android:strokeWidth="1.8"
        android:pathData="M54,62 m-9,0 a9,9 0 1,0 18,0 a9,9 0 1,0 -18,0"/>

    <!-- Iris (filled orange) -->
    <path
        android:fillColor="#E8720C"
        android:pathData="M54,62 m-4,0 a4,4 0 1,0 8,0 a4,4 0 1,0 -8,0"/>

    <!-- Pupil highlight -->
    <path
        android:fillColor="#FF9533"
        android:pathData="M54,62 m-1.6,0 a1.6,1.6 0 1,0 3.2,0 a1.6,1.6 0 1,0 -3.2,0"/>

</vector>
