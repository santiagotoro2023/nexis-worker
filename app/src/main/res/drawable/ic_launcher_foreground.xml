<?xml version="1.0" encoding="utf-8"?>
<!-- NeXiS logo: triangle with eye — orange on transparent (background layer provides dark bg) -->
<!-- Safe zone: 72x72 centered in 108x108, so drawable content from ~18,18 to ~90,90 -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Outer triangle — scaled to 70% to avoid appearing oversized on launcher -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#E8720C"
        android:strokeWidth="2.5"
        android:pathData="M54,37 L72,71 L36,71 Z"/>

    <!-- Center vertical hairline -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#E8720C"
        android:strokeWidth="0.8"
        android:strokeAlpha="0.35"
        android:pathData="M54,37 L54,71"/>

    <!-- Eye outer ring -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#E8720C"
        android:strokeWidth="1.8"
        android:pathData="M54,60 m-6,0 a6,6 0 1,0 12,0 a6,6 0 1,0 -12,0"/>

    <!-- Iris (filled orange) -->
    <path
        android:fillColor="#E8720C"
        android:pathData="M54,60 m-3,0 a3,3 0 1,0 6,0 a3,3 0 1,0 -6,0"/>

    <!-- Pupil highlight -->
    <path
        android:fillColor="#FF9533"
        android:pathData="M54,60 m-1.1,0 a1.1,1.1 0 1,0 2.2,0 a1.1,1.1 0 1,0 -2.2,0"/>

</vector>
